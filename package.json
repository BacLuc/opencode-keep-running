{
  "name": "opencode-keep-running",
  "version": "main",
  "description": "OpenCode plugin that detects when the agent is stuck and automatically continues the session",
  "main": "src/server.ts",
  "type": "module",
  "exports": {
    "./server": "./src/server.ts"
  },
  "files": [
    "src"
  ],
  "license": "MIT",
  "keywords": [
    "opencode",
    "plugin",
    "keep-running",
    "stuck-detection"
  ],
  "scripts": {
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit",
    "format": "prettier --write .",
    "format:check": "prettier --check ."
  },
  "devDependencies": {
    "@opencode-ai/plugin": "1.3.13",
    "@types/bun": "1.3.14",
    "prettier": "3.6.2",
    "typescript": "5.9.3",
    "vitest": "4.1.7"
  }
}
